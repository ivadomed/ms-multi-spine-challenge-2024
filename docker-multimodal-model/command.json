{
  "command-line": "python scripts/main.py --input-folder [INPUT_DATA] --output-folder [OUTPUT_DATA]",
  "name": "MS-Challenge-Segmentation",
  "tool-version": "1.0",
  "description": "Multimodal spinal cord lesion segmentation tool using nnUNet and SCT.",
  "container-image": {
    "type": "docker",
    "image": "your-dockerhub-username/ms-challenge-segmentation",
    "index": "https://index.docker.io"
  },
  "inputs": [
    {
      "id": "INPUT_DATA",
      "name": "Input Data Folder",
      "type": "Directory",
      "description": "Path to the directory containing the input data.",
      "command-line-flag": "--input-folder",
      "value-key": "[INPUT_DATA]"
    },
    {
      "id": "OUTPUT_DATA",
      "name": "Output Data Folder",
      "type": "Directory",
      "description": "Path where the output results will be saved.",
      "command-line-flag": "--output-folder",
      "value-key": "[OUTPUT_DATA]"
    }
  ],
  "output-files": [
    {
      "id": "output-dir",
      "name": "Output Results",
      "path-template": "[OUTPUT_DATA]",
      "description": "Directory containing the segmentation outputs."
    }
  ],
  "schema-version": "0.5"
}
